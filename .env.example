# WordPress Site URL (without trailing slash)
WP_URL=https://your-wordpress-site.com

# WordPress username
WP_USERNAME=your-username

# WordPress Application Password (Settings > Users > Application Passwords)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional: Maximum concurrent requests for link checker (default: 5)
CONCURRENCY=5

# Optional: Request timeout in milliseconds (default: 10000)
TIMEOUT=10000

# Optional: Directory for saving reports (default: ./reports)
REPORTS_DIR=./reports
