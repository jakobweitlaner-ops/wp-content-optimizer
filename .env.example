# WordPress Site URL (without trailing slash)
WP_URL=https://your-wordpress-site.com

# WordPress username
WP_USERNAME=your-username

# WordPress Application Password (Settings > Users > Application Passwords)
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Set to true if your server uses a self-signed SSL certificate
WP_INSECURE=false

# Optional: Maximum concurrent requests for link checker (default: 5)
CONCURRENCY=5

# Optional: Request timeout in milliseconds (default: 10000)
TIMEOUT=10000

# Optional: Link checker timeout in milliseconds (default: 20000)
LINK_TIMEOUT=20000

# Optional: Directory for saving reports (default: ./reports)
REPORTS_DIR=./reports

# Optional: Anthropic API key for AI-powered SEO suggestions (audit-seo --ai)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Business type for AI context (e.g. "Apartmenthaus", "Restaurant", "Online-Shop")
SITE_TYPE=Apartmenthaus
